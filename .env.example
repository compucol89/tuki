APP_NAME=Tuki
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tudominio.com
APP_TIMEZONE=America/Argentina/Buenos_Aires

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tuki
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ARCA / AFIP (Facturación electrónica)
ARCA_ENVIRONMENT=homologation
ARCA_ENABLE_ISSUING=false
ARCA_ENABLE_PREVIEW=true
ARCA_CUIT=
ARCA_CERT_PATH=
ARCA_KEY_PATH=
ARCA_CERT_PASSPHRASE=
ARCA_PUNTO_VENTA=1
ARCA_DEFAULT_COMMISSION_RATE=0.10
ARCA_DEFAULT_VAT_RATE=0
ARCA_INVOICE_MODEL=customer_service_fee_invoice
ARCA_ISSUER_NAME=
